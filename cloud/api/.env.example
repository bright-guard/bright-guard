# HTTP server
PORT=8080
APP_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:5173
# comma-separated; if empty, derived from APP_BASE_URL
ALLOWED_HOSTS=mcp-governance.infoblox.dev,bright-guard-cy6ozp2w3a-uc.a.run.app

# Postgres
DATABASE_URL=postgres://brightguard:brightguard@localhost:5433/brightguard?sslmode=disable

# Session signing key (32+ random bytes, base64 or hex)
SESSION_SECRET=change-me-to-32-bytes-of-random-please-rotate
# Mark session cookies Secure (set true in prod, false for local http)
SESSION_COOKIE_SECURE=false

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${APP_BASE_URL}/auth/google/callback
# Required unless DEV_LOGIN_ENABLED=true.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dev login — LOCAL DEV ONLY. When true, exposes POST /auth/dev/login that
# signs in any email without Google. NEVER enable in production.
DEV_LOGIN_ENABLED=false

# Email — used for org invitations.
# EMAIL_PROVIDER: "stub" (default; logs to stdout, no real send) or "gcp_email".
# For gcp_email, ADC must resolve (GOOGLE_APPLICATION_CREDENTIALS, Cloud Run SA, etc).
EMAIL_PROVIDER=stub
EMAIL_FROM=noreply@mcp-governance.infoblox.dev
# Optional: GCP project for the email API. Falls back to GOOGLE_CLOUD_PROJECT.
# GCP_PROJECT=bright-guard-prod
# GCP_EMAIL_LOCATION=global

# Comma-separated lower-cased emails that get auto-promoted to platform_admins
# on their first sign-in. Defaults to the project bootstrap pair when unset.
PLATFORM_ADMIN_SEED_EMAILS=daniel@danielgarcia.info,dgarcia@infoblox.com
